{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["message", "status"],
  "properties": {
    "message": {
      "type": "object",
      "patternProperties": {
        "^[a-z]+$": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "string",
      "enum": ["success"]
    }
  },
  "additionalProperties": false
}
