{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Saude do pipeline CI/CD: success rate, duracao, falhas por job e branch, feedback time.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "icon": "external link",
      "tags": [],
      "title": "GitHub Actions",
      "type": "link",
      "url": "https://github.com/rennangimenez/agibank-qa-automation-challenge/actions"
    },
    {
      "icon": "dashboard",
      "tags": [],
      "title": "Quality Overview",
      "type": "link",
      "url": "/grafana/d/quality-overview/quality-overview"
    },
    {
      "icon": "dashboard",
      "tags": [],
      "title": "Performance",
      "type": "link",
      "url": "/grafana/d/perf-jmeter/performance-jmeter"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Pipeline KPIs",
      "type": "row"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "#37872D", "value": null }] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 101,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["count"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Total Runs",
          "query": "SELECT \"duration\" FROM \"pipeline_runs\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Total Pipeline Runs",
      "type": "stat"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "yellow", "value": 85 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 102,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Success Rate",
          "query": "SELECT (sum(\"status_code\") / count(\"status_code\")) * 100 FROM \"pipeline_runs\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Pipeline Success Rate",
      "type": "stat"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 103,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Avg Duration",
          "query": "SELECT mean(\"duration\") FROM \"pipeline_runs\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Avg Pipeline Duration",
      "type": "stat"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 104,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["count"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Failures",
          "query": "SELECT \"duration\" FROM \"pipeline_runs\" WHERE \"status\" = 'failure' AND $timeFilter",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Total Failures",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "Pipeline Trends",
      "type": "row"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": false },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "web-tests" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "api-tests" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "performance" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "id": 201,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "alias": "$tag_job",
          "query": "SELECT \"duration\" FROM \"pipeline_runs\" WHERE $timeFilter GROUP BY \"job\"",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Pipeline Duration by Job",
      "type": "timeseries"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "spanNulls": false,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "failure" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "id": 202,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "alias": "$tag_status",
          "query": "SELECT count(\"duration\") FROM \"pipeline_runs\" WHERE $timeFilter GROUP BY time(1h), \"status\" fill(0)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Pipeline Results Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 300,
      "title": "Job Analysis",
      "type": "row"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "unit": "s"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "web-tests" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "api-tests" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "performance" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 16 },
      "id": 301,
      "options": {
        "legend": {
          "calcs": ["mean", "lastNotNull"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "alias": "$tag_job",
          "query": "SELECT mean(\"duration\") FROM \"pipeline_runs\" WHERE $timeFilter GROUP BY time(1h), \"job\" fill(null)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Avg Duration Trend by Job",
      "type": "timeseries"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "web-tests" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "api-tests" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "performance" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 16 },
      "id": 302,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "alias": "$tag_job",
          "query": "SELECT count(\"duration\") FROM \"pipeline_runs\" WHERE \"status\" = 'failure' AND $timeFilter GROUP BY time(1d), \"job\" fill(0)",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Failures by Job Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 400,
      "title": "Feedback & Stability",
      "type": "row"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 26 },
      "id": 401,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "alias": "Feedback Time",
          "query": "SELECT \"duration\" FROM \"pipeline_runs\" WHERE $timeFilter",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Feedback Time (Pipeline Duration)",
      "type": "timeseries"
    },
    {
      "datasource": "InfluxDB-JMeter",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "web" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "api" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 26 },
      "id": 402,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "alias": "$tag_test_type",
          "query": "SELECT \"flaky_count\" FROM \"test_stability\" WHERE $timeFilter GROUP BY \"test_type\"",
          "rawQuery": true,
          "refId": "A",
          "resultFormat": "time_series"
        }
      ],
      "title": "Flaky Tests by Suite",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["agibank", "qa", "pipeline", "cicd"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Pipeline & Delivery Health",
  "uid": "pipeline-health",
  "version": 1
}
