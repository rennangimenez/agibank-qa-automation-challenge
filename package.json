{
  "name": "agibank-qa-automation-challenge",
  "private": true,
  "description": "Dev tooling for QA automation project (hooks, formatting)",
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write \"**/*.{yml,yaml,json,md}\"",
    "format:check": "prettier --check \"**/*.{yml,yaml,json,md}\""
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "lint-staged": {
    "*.{yml,yaml,json,md}": [
      "prettier --write"
    ]
  }
}
